#!/bin/sh

ping_server="9.9.9.9"
max_wait=120 # seconds

# Check ModemManager
lteproto=$(grep -c "proto 'modemmanager'" /etc/config/network)
[ "$lteproto" -ne 0 ] && { echo "Script not compatible with ModemManager"; exit 1; }

# Help function
usage() {
cat <<EOF
Usage: $(basename "$0") [options]

Options:
  -h           Show this help
  -v           Verbose/debug mode
  -p server    Start continuous ping to SERVER before querying modem (default: 9.9.9.9)

Description:
  Queries modem for current LTE serving cell information using AT+QENG="servingcell".
  Provides Cell ID, PCI, EARFCN, and link to LTEItaly.
EOF
exit 0
}

verbose=0
traffic_pid=""
tmp_file=""

# Cleanup function: stop ping and remove temporary files
cleanup() {
    [ -n "$traffic_pid" ] && kill "$traffic_pid" 2>/dev/null || true
    [ -n "$tmp_file" ] && rm -f "$tmp_file"
}

# Trap CTRL+C, kill and normal exit
trap 'echo; echo "Interrupted. Cleaning up..."; cleanup; exit 1' INT TERM
trap 'cleanup' EXIT

# Parse options
while getopts "hvp:" opt; do
    case "$opt" in
        h) usage ;;
        v) verbose=1 ;;
        p) ping_server="$OPTARG" ;;
        *) usage ;;
    esac
done

start_epoch=$(date +%s)

# Start continuous ping to generate traffic
[ "$verbose" -eq 1 ] && echo "Starting continuous ping to $ping_server"
ping "$ping_server" > /dev/null 2>&1 &
traffic_pid=$!

# Function to send AT command and store output in $tmp_file
send_at() {
    tmp_file=$(mktemp)
    atstring=$(printf "%s\r\n" "$1")
    picocom "/dev/ttyUSB2" --nolock --exit-after "600" --quiet -t "$atstring" --logfile "$tmp_file" > /dev/null
}

[ "$verbose" -eq 1 ] && echo "Waiting 2 seconds before sending AT+QENG=\"servingcell\"..."
sleep 2

# Poll AT+QENG="servingcell" until valid response or timeout
while true; do
    send_at 'AT+QENG="servingcell"'

    line=$(grep '+QENG: "servingcell"' "$tmp_file" 2>/dev/null)

    if [ -n "$line" ]; then
        break
    fi

    elapsed=$(( $(date +%s) - start_epoch ))
    [ "$elapsed" -ge "$max_wait" ] && { echo "Timeout: no LTE cell attached within $max_wait seconds"; exit 1; }

    [ "$verbose" -eq 1 ] && { echo "Debug output:"; cat "$tmp_file"; }
    rm -f "$tmp_file"
    tmp_file=""
    sleep 2
done

# Parse fields from AT+QENG="servingcell" response
mcc=$(echo "$line" | cut -d',' -f5)
mnc=$(echo "$line" | cut -d',' -f6)

cellid_raw=$(echo "$line" | cut -d',' -f7)
# The ECI (E-UTRAN Cell Identity) field is 28-bit hex (7 chars):
#   - first 5 chars = eNB ID (20 bit), range 0-1048575
#   - last 2 chars  = Sector/Cell ID (8 bit), range 0-255
# Formula: ECI = (eNB ID << 8) | Sector ID
# Some operators return fewer than 7 hex chars (e.g. Fastweb MNC=10 returns 6 chars).
# Zero-pad to 7 chars to ensure correct split regardless of operator.
# Note: home eNodeB (femtocell) uses a different split (28-bit eNB ID) - this may not apply.
# Reference: 3GPP TS 36.413 - https://www.rfwireless-world.com/calculators/lte-ecgi-eci-calculator

cellid_padded=$(printf "%07s" "$cellid_raw" | tr ' ' '0')

cellid_hex=$(echo "$cellid_padded" | cut -c1-5)
pci=$(echo "$line" | cut -d',' -f8)
earfcn=$(echo "$line" | cut -d',' -f9)

# Validate Cell ID hex field before conversion
if [ -z "$cellid_raw" ] || ! echo "$cellid_raw" | grep -qiE '^[0-9A-Fa-f]+$'; then
    echo "Cell ID not available or invalid: '$cellid_raw'"
    [ "$verbose" -eq 1 ] && { echo "Debug output:"; cat "$tmp_file"; }
    exit 1
fi

# Convert hex Cell ID to decimal
cellid=$(printf "%d\n" "0x$cellid_hex")
mccmnc="$mcc$mnc"

end_epoch=$(date +%s)
duration=$((end_epoch - start_epoch))

echo "Raw line: $line"
echo "Cell ID LTEItaly: https://lteitaly.it/it/internal/map.php#bts=$mccmnc.$cellid"
[ "$verbose" -eq 1 ] && echo "Elapsed time: ${duration} seconds"
