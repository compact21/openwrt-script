#!/bin/sh
#set -x

logheader="atcmd"
nologger=0
delaytime="600"
atcommand=""
savefile=""
ttyport="/dev/ttyUSB2"
smart_qnwlock=0
ping_target="8.8.8.8"
qnwlock_max_wait=70
qnwlock_ping_interval=2

# Check compatibility with ModemManager
lteproto=$(grep -c "proto 'modemmanager'" /etc/config/network)
if [ "$lteproto" -eq 1 ]; then
    printf "Script not compatible with \"ModemManager\"\n"
    exit 1
fi

# Check if atcmd is blocked by watchdog_mbim
atcmd_block_file="/tmp/watchdog/atcmd_block"
if [ -f "$atcmd_block_file" ]; then
    printf "\nI can't give at commands, the file %s exists\n" "$atcmd_block_file"
    exit 2
fi

# Save the original command for logging
orig_command="$0"
for arg in "$@"; do
    orig_command="$orig_command '$(printf "%s" "$arg" | sed "s/'/'\\\\''/g")'"
done

# Usage
usage() {
cat <<'EOF'
========================================================================================
                            AT Command Utility - Usage Guide
---------------------------------------------------------------------------------------
 WARNING: Use with caution! If you are not sure what a command does DO NOT EXECUTE IT.
---------------------------------------------------------------------------------------

Usage:
  atcmd [options] "AT-COMMAND"

Options:
  -a, --at              AT command
  -d, --delay <ms>      Delay in milliseconds (default: 600)
  -o, --output <file>   Save output (only /tmp/atcmd/)
  -n, --no-log          Disable syslog logging
  -S, --smart-qnwlock   Apply AT+QNWLOCK with connectivity check and fallback
  -h, --help            Show this help


Notes:

  - "-S" "--smart-qnwlock" is valid ONLY with: AT+QNWLOCK="common/4g",<n>,...
  - If -a/--at is omitted, the first non-option argument is treated as the AT command.
  - The default AT port is /dev/ttyUSB2.
  - This utility is not compatible with ModemManager.
  - Output files are restricted to /tmp/atcmd/ for safety reasons.
  - AT commands are blocked if /tmp/watchdog/atcmd_block exists.

Warning:

  - Many AT commands modify persistent modem settings (NVRAM).
  - Some commands may cause loss of network connectivity or remote access.
  - Some commands require a longer delay (-d) to return complete output.
  - Commands that do not return 'OK' may be reported as failed.
  - Commands and responses are logged to syslog by default (use -n to disable).

Examples:

atcmd 'AT'; # Basic communication test, same as: atcmd -a 'AT'
atcmd 'ATI'; # Show device information, same as: atcmd -a 'ATI'
atcmd 'AT+CVERSION'; # Show firmware version
ping -c 5 -W 2 8.8.8.8 > /dev/null 2>&1; atcmd 'AT+QCAINFO'; # Run ping, then show cell info
atcmd 'AT+CGPADDR=1'; # Show current IP address
atcmd 'AT+CSQ'; # Show signal quality
atcmd -d 500 'AT+CSQ';  # delay before reading response
atcmd 'AT+QRSRP'; # Show RSRP signal level
atcmd 'AT+QENG="servingcell"'; # Show serving cell info
atcmd 'AT+QENG="neighbourcell"'; # Show neighbouring cells
atcmd 'AT+QNETINFO="servingcell"'; # Show current network info
atcmd 'AT+CPMS?'; # Show actual SMS storage
atcmd 'AT+CPMS="ME","ME","ME"'; atcmd 'AT+CSAS'; # Set and save SMS storage to ME
atcmd 'AT+QCFG="band",0,5,1'; # Use LTE bands 1+3 only
atcmd 'AT+QCFG="band",0,45,1'; # Use LTE bands 1+3+7 only
atcmd 'AT+QCFG="band",0,80045,1'; # Use LTE bands 1+3+7+20 only
atcmd 'AT+QCFG="band",8d0,1A0080800D5,1'; # Enable all supported LTE bands (e.g. EG18-EU)
atcmd 'AT+QCFG="usbnet"'; # Show USB network type (0=qmi, 1=ecm, 2=mbim) ** WARNING: mode 3=RNDIS is NOT supported on Linux but only Windows **
atcmd 'AT+QCFG="usbcfg",0x2C7C,0x0512,1,1,1,1,1,1,0'; # Enable ADB interface
atcmd 'AT+QCFG="call_control",1,1'; # Disable voice call support

---------------------------------------------------------------------------------------

atcmd 'AT+QNWLOCK="common/4g",0'; # Disable cell lock
atcmd 'AT+QNWLOCK="common/4g"'; # Show current cell lock status

# Smart QNLOCK example
atcmd -S 'AT+QNWLOCK="common/4g",1,1650,100; # Monte Bondone Cima Palon 230131 or 231131
atcmd -S 'AT+QNWLOCK="common/4g",3,1650,100,1650,65,1500,50'; # Monte Bondone Cima Palon 230131 or 231131

---------------------------------------------------------------------------------------

========================================================================================
EOF
echo "Current date: $(date)"
exit 0
}

# Send AT command
send_at() {
    at="$1"
    delay="${2:-$delaytime}"
    log_label="${3:-$orig_command}"
    tmpfile=$(mktemp)

    # Create AT string with CR/LF for modem
    atstring=$(printf "%s\r\n" "$at")

    # Send AT command via picocom
    picocom "$ttyport" --exit-after "$delay" --quiet -t "$atstring" --logfile "$tmpfile" > /dev/null

    # Check if command returned OK
    if ! grep -q "OK" "$tmpfile"; then
        cat "$tmpfile"
        rm -f "$tmpfile"
        return 1
    fi

    # Logging or saving output
    if [ -n "$savefile" ]; then
        [ "$nologger" -eq 0 ] && logger -t "$logheader" "$log_label"
        echo "$(date)" >> "$savefile"
        cat "$tmpfile" >> "$savefile"
    else
        [ "$nologger" -eq 0 ] && logger -t "$logheader" "$log_label"
        tail -n +2 "$tmpfile" | grep -E '[^[:space:]]' | while read line; do
            [ "$nologger" -eq 0 ] && logger -t "$logheader" "$line"
            done
        cat "$tmpfile"
    fi

    rm -f "$tmpfile"
    return 0
}

# Apply cell lock with fall-back
qnwlock_with_check() {

    lock_cmd="$1"
    fallback_command='AT+QNWLOCK="common/4g",0'

    logger -t "$logheader" "smart-qnwlock: applying lock via: $orig_command"
    send_at "$lock_cmd" "$delaytime" "$orig_command"
    
    elapsed=0
    while [ $elapsed -lt $qnwlock_max_wait ]; do
        ping -c 1 -W 1 "$ping_target" >/dev/null 2>&1 && break
        sleep "$qnwlock_ping_interval"
        elapsed=$((elapsed + qnwlock_ping_interval))
    done

    if ping -c 2 -W 1 "$ping_target" >/dev/null 2>&1; then
        logger -t "$logheader" "smart-qnwlock: LTE connected successfully after cell-lock activation (${elapsed}s)"
        return 0
    fi

    logger -t "$logheader" "smart-qnwlock: LTE failed after lock, applying fallback"

    send_at "$fallback_command" "$delaytime" "$fallback_command"

    elapsed=0
    while [ $elapsed -lt $qnwlock_max_wait ]; do
        ping -c 1 -W 1 "$ping_target" >/dev/null 2>&1 && break
        sleep "$qnwlock_ping_interval"
        elapsed=$((elapsed + qnwlock_ping_interval))
    done

    if ping -c 2 -W 1 "$ping_target" >/dev/null 2>&1; then
        logger -t "$logheader" "smart-qnwlock: LTE connected successfully after fallback (${elapsed}s)"
        return 0
    else
        logger -t "$logheader" "smart-qnwlock: LTE failed after fallback"
        return 12
    fi
}

# Parse arguments
while [ $# -gt 0 ]; do
    case "$1" in
        -a|--at)
            shift
            atcommand="$1"
            ;;
        -d|--delay)
            shift
            delaytime="$1"
            ;;
        -o|--output)
            shift
            savefile="$1"
            ;;
        -n|--no-log)
            nologger=1
            ;;
        -S|--smart-qnwlock)
            smart_qnwlock=1
            ;;
        -h|--help)
            usage
            ;;
        *)
            if [ -z "$atcommand" ]; then
                atcommand="$1"
            else
                printf "Unknown option: %s\n" "$1"
                usage
            fi
            ;;
    esac
    shift
done

# validations
if [ -z "$atcommand" ]; then
    #printf "ERROR: missing AT command\n"
    #exit 3
    usage
fi

# validate delaytime numeric
case "$delaytime" in
    ''|*[!0-9]*)
        printf "ERROR: delay must be numeric\n"
        exit 6
        ;;
esac

# validate savefile path
if [ -n "$savefile" ]; then
    case "$savefile" in
        /tmp/atcmd/*) ;;
        *)
            printf "ERROR: output file must be inside /tmp/atcmd/\n"
            exit 7
            ;;
    esac
    mkdir -p /tmp/atcmd
fi

# smart qnwlock handling
if [ "$smart_qnwlock" -eq 1 ]; then
    case "$atcommand" in
        AT+QNWLOCK=\"common/4g\",[1-9]*)
        qnwlock_with_check "$atcommand"
        exit $?
        ;;
        *)
        printf "error: --smart-qnwlock requires AT+QNWLOCK=\"common/4g\",<n>\n"
        exit 4
        ;;
    esac
fi

# standard at execution
send_at "$atcommand"
exit $?
