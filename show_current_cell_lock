#!/bin/sh

# Check ModemManager
lteproto=$(grep -c "proto 'modemmanager'" /etc/config/network)
[ "$lteproto" -ne 0 ] && { echo "Script not compatible with ModemManager"; exit 1; }

# Help function
usage() {
cat <<EOF
Usage: $(basename "$0") [options]

Options:
  -h      Show this help
  -v      Verbose/debug mode: show modem output if no cell lock is detected

Description:
  Queries modem for current LTE cell-lock status using AT+QNWLOCK="common/4g"
EOF
exit 0
}

verbose=0

# Parse options
while getopts "hv" opt; do
    case "$opt" in
        h) usage ;;
        v) verbose=1 ;;
        *) usage ;;
    esac
done

# Function to send AT command and check cell-lock
send_at() {
    at="$1"
    tmpfile=$(mktemp)
    atstring=$(printf "%s\r\n" "$at")
    picocom "/dev/ttyUSB2" --exit-after "600" --quiet -t "$atstring" --logfile "$tmpfile" > /dev/null

    lock_line=$(grep '+QNWLOCK:' "$tmpfile")

    if [ -n "$lock_line" ]; then
        if echo "$lock_line" | grep -q ',0'; then
            echo "No cell lock detected"
            [ "$verbose" -eq 1 ] && { echo "Debug output:"; cat "$tmpfile"; }
        else
            echo "Cell lock detected:"
            echo "$lock_line"
        fi
    else
        echo "No cell lock detected"
        [ "$verbose" -eq 1 ] && { echo "Debug output:"; cat "$tmpfile"; }
    fi

    rm -f "$tmpfile"
}

# Execute command
send_at 'AT+QNWLOCK="common/4g"'
