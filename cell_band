#!/bin/sh

ping_server="9.9.9.9"
max_wait=120 # second

# Check ModemManager
lteproto=$(grep -c "proto 'modemmanager'" /etc/config/network)
[ "$lteproto" -ne 0 ] && { echo "Script not compatible with ModemManager"; exit 1; }

verbose=0
traffic_mode="ping"

# Help function
usage() {
cat <<EOF
Usage: $(basename "$0") [options]

Options:
  -h           Show this help
  -d URL       Download a file from URL instead of ping (use files >10 MB for reliable CA detection)
  -p SERVER    Server to ping (default: 9.9.9.9)
  -v           Verbose/debug mode

Examples:
  $0
  $0 -p 8.8.8.8
  $0 -v -p 1.1.1.1
  $0 -d http://speedtest.tele2.net/10MB.zip
  $0 -v -d http://speedtest.tele2.net/100MB.zip
EOF
exit 0
}

# Parse options
while getopts "hd:p:v" opt; do
    case "$opt" in
        h) usage ;;
        d) traffic_mode="download"; download_url="$OPTARG" ;;
        p) ping_server="$OPTARG" ;;
        v) verbose=1 ;;
        *) usage ;;
    esac
done

# Function: convert LTE bandwidth code to MHz
bw_to_mhz() {
    case $1 in
        6) echo 1.4 ;;
        15) echo 3 ;;
        25) echo 5 ;;
        50) echo 10 ;;
        75) echo 15 ;;
        100) echo 20 ;;
        *) echo 0 ;;
    esac
}

# Cleanup function
cleanup() {
    [ -n "$traffic_pid" ] && kill "$traffic_pid" 2>/dev/null || true
    [ -n "$file" ] && rm -f "$file"
    [ -n "$temp_download" ] && rm -f "$temp_download"
}
trap cleanup INT TERM

start_epoch=$(date +%s)

# Generate traffic
if [ "$traffic_mode" = "ping" ]; then
    [ "$verbose" -eq 1 ] && echo "Starting ping to $ping_server"
    ping "$ping_server" > /dev/null 2>&1 &
    traffic_pid=$!
else
    [ -z "$download_url" ] && { echo "Error: missing URL for download"; exit 1; }
    [ "$verbose" -eq 1 ] && echo "Download mode enabled. Tip: file >10MB for reliable CA detection."
    temp_download=$(mktemp /tmp/cellband_download.XXXXXX)
    [ "$verbose" -eq 1 ] && echo "Downloading $download_url to $temp_download"
    curl -s -o "$temp_download" "$download_url" &
    traffic_pid=$!
fi

[ "$verbose" -eq 1 ] && echo "Waiting 5 seconds before sending AT+QCAINFO..."
sleep 5

# Send AT+QCAINFO command and save output, with $max_wait timeout
file=$(mktemp)
while true; do
    picocom -t "$(printf 'AT+QCAINFO\r\n')" "/dev/ttyUSB2" --nolock --exit-after "300" --quiet --logfile "$file" > /dev/null 2>&1
    grep -q '+QCAINFO:' "$file" && break
    elapsed=$(( $(date +%s) - start_epoch ))
    [ "$elapsed" -ge "$max_wait" ] && { echo "Timeout reached ($max_wait)s"; break; }
    sleep 2
done

kill "$traffic_pid" 2>/dev/null || true

# Extract and display PCC/SCC bands from modem output
grep '+QCAINFO:' "$file"

total=0
scc_count=0
pcc_count=0
line_out=""

while IFS= read -r line; do
    echo "$line" | grep -qi '+QCAINFO:' || continue
    type=$(echo "$line" | cut -d',' -f1 | tr -d '"')
    bw_code=$(echo "$line" | cut -d',' -f3 | tr -d '"')
    band=$(echo "$line" | cut -d',' -f4 | tr -d '"')
    mhz=$(bw_to_mhz "$bw_code")
    [ "$mhz" = "0" ] && continue

    case "$type" in
        *pcc*)
            pcc_count=$((pcc_count+1))
            entry="PCC-$band ${mhz} MHz"
            ;;
        *scc*)
            scc_count=$((scc_count+1))
            entry="SCC$scc_count-$band ${mhz} MHz"
            ;;
    esac

    [ -n "$line_out" ] && line_out="$line_out | $entry" || line_out="$entry"
    total=$(awk "BEGIN {print $total+$mhz}")
done < "$file"

echo "$line_out"
echo "Total aggregated bandwidth: $total MHz"

end_epoch=$(date +%s)
duration=$((end_epoch - start_epoch))
[ "$verbose" -eq 1 ] && echo "Elapsed time: ${duration} seconds"

cleanup
