#!/bin/sh

#set -x

DEVICE="/dev/ttyUSB2"

# Convert LTE bandwidth code to MHz
bw_to_mhz() {
    case $1 in
        6) echo 1.4 ;;
        15) echo 3 ;;
        25) echo 5 ;;
        50) echo 10 ;;
        75) echo 15 ;;
        100) echo 20 ;;
        *) echo 0 ;;
    esac
}

# Check if ModemManager is configured (not compatible)
lteproto=$(grep -c "proto 'modemmanager'" /etc/config/network)
if [ "$lteproto" -ne 0 ]; then
    echo "Script not compatible with \"ModemManager\""
    exit 1
fi

# Record start time
START_EPOCH=$(date +%s)

# Generate light traffic: ping continuously until a response is received
ping 9.9.9.9 > /dev/null 2>&1 &
PING_PID=$!

# Create temporary file for modem output
FILE=$(mktemp)

# Send AT+QCAINFO command and log output, with 120s timeout
while true; do
    picocom -t "$(printf 'AT+QCAINFO\r\n')" "$DEVICE" --nolock --exit-after 300 --quiet --logfile "$FILE" > /dev/null 2>&1

    # Exit loop if at least one +QCAINFO line is received
    grep -q '+QCAINFO:' "$FILE" && break

    # Check elapsed time
    ELAPSED=$(( $(date +%s) - START_EPOCH ))
    [ "$ELAPSED" -ge 120 ] && { echo "Timeout reached (120s)"; break; }

    sleep 2
done

# Stop ping process
kill "$PING_PID" 2>/dev/null || true

# Print raw modem lines
grep '+QCAINFO:' "$FILE"

# Initialize counters
TOTAL=0
SCC_COUNT=0
PCC_COUNT=0
LINE_OUT=""

# Parse PCC and SCC information
while IFS= read -r LINE; do
    echo "$LINE" | grep -qi '+QCAINFO:' || continue

    TYPE=$(echo "$LINE" | cut -d',' -f1 | tr -d '"')
    BW_CODE=$(echo "$LINE" | cut -d',' -f3 | tr -d '"')
    BAND=$(echo "$LINE" | cut -d',' -f4 | tr -d '"')

    MHZ=$(bw_to_mhz "$BW_CODE")
    [ "$MHZ" = "0" ] && continue

    case "$TYPE" in
        *pcc*)
            PCC_COUNT=$((PCC_COUNT+1))
            ENTRY="PCC-$BAND ${MHZ} MHz"
            ;;
        *scc*)
            SCC_COUNT=$((SCC_COUNT+1))
            ENTRY="SCC$SCC_COUNT-$BAND ${MHZ} MHz"
            ;;
    esac

    # Build aggregated line string
    if [ -n "$LINE_OUT" ]; then
        LINE_OUT="$LINE_OUT | $ENTRY"
    else
        LINE_OUT="$ENTRY"
    fi

    # Sum total bandwidth using awk for decimals
    TOTAL=$(awk "BEGIN {print $TOTAL+$MHZ}")

done < "$FILE"

# Print aggregated information
echo "$LINE_OUT"
echo "Total aggregated bandwidth: $TOTAL MHz"

# Record end time and duration
END_EPOCH=$(date +%s)
DURATION=$((END_EPOCH - START_EPOCH))
echo "Elapsed time: ${DURATION} seconds"

# Remove temporary file
rm "$FILE"
